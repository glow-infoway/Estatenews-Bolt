---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const [citiesRes, projectsRes, collectionsRes] = await Promise.all([
  supabase.from('cities').select('id', { count: 'exact', head: true }),
  supabase.from('projects').select('id', { count: 'exact', head: true }),
  supabase.from('collections').select('id', { count: 'exact', head: true }),
]);
---

<AdminLayout title="Dashboard" activeTab="dashboard">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        </div>
        <div>
          <p class="text-sm text-gray-500">Cities</p>
          <p class="text-2xl font-bold text-gray-900">{citiesRes.count || 0}</p>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-accent-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        </div>
        <div>
          <p class="text-sm text-gray-500">Projects</p>
          <p class="text-2xl font-bold text-gray-900">{projectsRes.count || 0}</p>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        </div>
        <div>
          <p class="text-sm text-gray-500">Collections</p>
          <p class="text-2xl font-bold text-gray-900">{collectionsRes.count || 0}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Deploy Site -->
  <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-2">Deploy Static Site</h2>
    <p class="text-sm text-gray-500 mb-4">Push a commit to GitHub to trigger Cloudflare Pages to rebuild and deploy all static pages with updated data and sitemap.</p>
    <button
      id="rebuild-btn"
      class="px-6 py-2.5 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-lg transition-colors text-sm inline-flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Deploy Site
    </button>
    <div id="rebuild-status" class="hidden mt-3 text-sm"></div>
  </div>

  <!-- Quick Links -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/admin/cities" class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm hover:shadow-md transition-shadow flex items-center gap-4">
      <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      </div>
      <div>
        <p class="font-medium text-gray-900 text-sm">Manage Cities</p>
        <p class="text-xs text-gray-500">Add, edit, delete cities</p>
      </div>
    </a>
    <a href="/admin/projects" class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm hover:shadow-md transition-shadow flex items-center gap-4">
      <div class="w-10 h-10 bg-accent-50 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      </div>
      <div>
        <p class="font-medium text-gray-900 text-sm">Manage Projects</p>
        <p class="text-xs text-gray-500">Add, edit, delete projects</p>
      </div>
    </a>
    <a href="/admin/collections" class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm hover:shadow-md transition-shadow flex items-center gap-4">
      <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      </div>
      <div>
        <p class="font-medium text-gray-900 text-sm">Manage Collections</p>
        <p class="text-xs text-gray-500">Add, edit, delete collections</p>
      </div>
    </a>
  </div>
</AdminLayout>

<script>
  const rebuildBtn = document.getElementById('rebuild-btn');
  const rebuildStatus = document.getElementById('rebuild-status');

  rebuildBtn?.addEventListener('click', async () => {
    rebuildBtn.setAttribute('disabled', 'true');
    rebuildBtn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Deploying...';
    rebuildStatus!.className = 'mt-3 text-sm text-gray-500';
    rebuildStatus!.textContent = 'Pushing commit to GitHub to trigger Cloudflare Pages build...';

    try {
      const token = document.cookie.match(/sb-auth-token=([^;]+)/)?.[1];
      const res = await fetch('/admin/api/rebuild', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
      });
      const data = await res.json();

      if (res.ok) {
        rebuildStatus!.className = 'mt-3 text-sm text-green-600';
        rebuildStatus!.textContent = 'Deploy triggered. Commit pushed to GitHub. Cloudflare Pages will rebuild and deploy the site automatically.';
      } else {
        rebuildStatus!.className = 'mt-3 text-sm text-red-600';
        rebuildStatus!.textContent = data.error || 'Deploy failed.';
      }
    } catch {
      rebuildStatus!.className = 'mt-3 text-sm text-red-600';
      rebuildStatus!.textContent = 'Failed to trigger deploy.';
    }

    rebuildBtn.removeAttribute('disabled');
    rebuildBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Deploy Site';
  });
</script>
