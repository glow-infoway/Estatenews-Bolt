---
interface Props {
  projectType: string;
  citySlug: string;
  cityName: string;
  locations: string[];
  amenities: string[];
  statuses: string[];
  selectedLocation?: string;
  selectedStatus?: string;
  selectedAmenity?: string;
}

const { projectType, citySlug, cityName, locations, amenities, statuses, selectedLocation, selectedStatus, selectedAmenity } = Astro.props;
const otherType = projectType === 'residential' ? 'commercial' : 'residential';
---

<aside class="w-full lg:w-72 flex-shrink-0">
  <div class="bg-white rounded-xl shadow-md border border-gray-100 p-5 sticky top-20">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-lg font-semibold text-gray-900">Filters</h3>
      <button id="clear-filters" class="text-xs text-accent-600 hover:text-accent-700 font-medium transition-colors">Clear All</button>
    </div>

    <div class="mb-5">
      <label class="block text-sm font-medium text-gray-700 mb-2">Project Type</label>
      <div class="flex gap-2">
        <a href={`/${citySlug}/${projectType}`} class="flex-1 text-center text-xs font-medium px-3 py-2 rounded-lg bg-primary-700 text-white">
          {projectType === 'residential' ? 'Residential' : 'Commercial'}
        </a>
        <a href={`/${citySlug}/${otherType}`} class="flex-1 text-center text-xs font-medium px-3 py-2 rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors">
          {otherType === 'residential' ? 'Residential' : 'Commercial'}
        </a>
      </div>
    </div>

    <div class="mb-5">
      <label for="filter-location" class="block text-sm font-medium text-gray-700 mb-2">Locality</label>
      <select id="filter-location" data-filter="location" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 bg-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none">
        <option value="">All Localities</option>
        {locations.map((loc) => (
          <option value={loc} selected={loc === selectedLocation}>{loc}</option>
        ))}
      </select>
    </div>

    <div class="mb-5">
      <label for="filter-status" class="block text-sm font-medium text-gray-700 mb-2">Project Status</label>
      <select id="filter-status" data-filter="status" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 bg-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none">
        <option value="">All Status</option>
        {statuses.map((s) => (
          <option value={s} selected={s === selectedStatus}>{s === 'new-launch' ? 'New Launch' : s === 'under-construction' ? 'Under Construction' : 'Ready to Move'}</option>
        ))}
      </select>
    </div>

    <div>
      <label for="filter-amenity" class="block text-sm font-medium text-gray-700 mb-2">Amenities</label>
      <select id="filter-amenity" data-filter="amenity" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 bg-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none">
        <option value="">All Amenities</option>
        {amenities.map((a) => (
          <option value={a} selected={a === selectedAmenity}>{a}</option>
        ))}
      </select>
    </div>
  </div>
</aside>
