---
interface Props {
  items: { name: string; url: string }[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="bg-gray-50 border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <ol class="flex items-center gap-2 text-sm flex-wrap">
      <li>
        <a href="/" class="text-gray-500 hover:text-primary-700 transition-colors">Home</a>
      </li>
      {items.map((item, i) => (
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          {i === items.length - 1 ? (
            <span class="text-primary-700 font-medium">{item.name}</span>
          ) : (
            <a href={item.url} class="text-gray-500 hover:text-primary-700 transition-colors">{item.name}</a>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>
