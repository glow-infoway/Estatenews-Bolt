---
import type { City } from '../lib/types';

interface Props {
  city: City;
  projectCount?: number;
}

const { city, projectCount } = Astro.props;
---

<a href={`/${city.slug}`} class="group block relative rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300">
  <div class="aspect-[16/9] overflow-hidden">
    <img
      src={city.hero_image}
      alt={`Real estate projects in ${city.name}, ${city.state}`}
      loading="lazy"
      width="400"
      height="225"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </div>
  <div class="absolute inset-0 bg-gradient-to-t from-primary-900/90 via-primary-900/40 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 p-5">
    <h3 class="text-xl font-bold text-white mb-1">{city.name}</h3>
    <p class="text-sm text-gray-200">{city.state}</p>
    {projectCount && (
      <p class="text-xs text-accent-400 mt-2 font-medium">{projectCount} Projects Available</p>
    )}
  </div>
</a>
