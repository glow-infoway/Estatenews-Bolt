---
const cities = [
  { name: 'Ahmedabad', slug: 'ahmedabad' },
  { name: 'Surat', slug: 'surat' },
  { name: 'Rajkot', slug: 'rajkot' },
];
---

<header class="bg-primary-800 text-white sticky top-0 z-50 shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight">
        <svg class="w-8 h-8 text-accent-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/>
        </svg>
        <span>Prop<span class="text-accent-500">Discover</span></span>
      </a>
      <nav class="hidden md:flex items-center gap-6">
        <a href="/" class="text-gray-200 hover:text-white transition-colors text-sm font-medium">Home</a>
        {cities.map((city) => (
          <div class="relative group">
            <a href={`/${city.slug}`} class="text-gray-200 hover:text-white transition-colors text-sm font-medium">
              {city.name}
            </a>
            <div class="absolute left-0 top-full mt-1 bg-white rounded-lg shadow-xl py-2 min-w-[200px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <a href={`/${city.slug}/residential`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-700">Residential Projects</a>
              <a href={`/${city.slug}/commercial`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-700">Commercial Projects</a>
            </div>
          </div>
        ))}
        <a href="/collections" class="text-gray-200 hover:text-white transition-colors text-sm font-medium">Collections</a>
      </nav>
      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-primary-700 transition-colors" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden md:hidden bg-primary-900 border-t border-primary-700">
    <div class="px-4 py-3 space-y-2">
      <a href="/" class="block py-2 text-gray-200 hover:text-white text-sm">Home</a>
      {cities.map((city) => (
        <div class="py-1">
          <a href={`/${city.slug}`} class="block py-1 text-gray-200 hover:text-white text-sm font-medium">{city.name}</a>
          <a href={`/${city.slug}/residential`} class="block py-1 pl-4 text-gray-300 hover:text-white text-xs">Residential</a>
          <a href={`/${city.slug}/commercial`} class="block py-1 pl-4 text-gray-300 hover:text-white text-xs">Commercial</a>
        </div>
      ))}
      <a href="/collections" class="block py-2 text-gray-200 hover:text-white text-sm">Collections</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
